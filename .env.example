# ============================================
# Supabase
# ============================================
# Dapatkan di Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# RAHASIA — JANGAN expose ke client
SUPABASE_SERVICE_ROLE_KEY=

# Database (Supabase Postgres, Transaction Pooler / port 6543)
# Dapatkan di Project Settings → Database → Connection string → Transaction pooler
DATABASE_URL=

# ============================================
# Vercel Blob (storage foto absensi)
# ============================================
# Auto-pulled via `pnpm dlx vercel env pull .env.local`
BLOB_READ_WRITE_TOKEN=

# ============================================
# App config
# ============================================
# Opsional: batasi email yang boleh sign-up. Kosongkan untuk semua domain.
ALLOWED_EMAIL_DOMAIN=

# Jam kerja standar untuk hitung flag Telat / Pulang Cepat
WORK_START=08:00
WORK_END=17:00

# Cron auth (auto-generate kalau pakai Vercel Cron)
CRON_SECRET=
