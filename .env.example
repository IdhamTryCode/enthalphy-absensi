# NextAuth
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth (Authorization Code grant — untuk login user)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Google Service Account (untuk tulis ke Sheets & Drive)
# JSON key di-encode base64 (hindari masalah newline/quote di private_key).
# Cara bikin: cat key.json | base64 -w0   (atau: base64 -i key.json)
GOOGLE_SERVICE_ACCOUNT_B64=

# Target resource
GOOGLE_SHEET_ID=

# Vercel Blob (storage foto absensi)
# Dapatkan di: Vercel dashboard → project → Storage → Create Blob store → .env.local tab
BLOB_READ_WRITE_TOKEN=

# Akses kontrol
# Biarkan kosong = semua email Google boleh login
ALLOWED_EMAIL_DOMAIN=
# Daftar email admin, pisahkan dengan koma
ADMIN_EMAILS=

# Jam kerja standar (WIB, format HH:mm, Senin–Jumat)
WORK_START=08:00
WORK_END=17:00
